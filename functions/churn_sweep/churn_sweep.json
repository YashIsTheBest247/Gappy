{
  "name": "churn_sweep",
  "description": "Scans for at-risk customers (low CSAT, negative sentiment, escalations) and opens a proactive retention ticket with a drafted outreach for human approval. Runs on a cron.",
  "type": "API",
  "code": { "$file": "code.py" },
  "permissions": {
    "grants": [
      { "resource_type": "datastore_table", "resource_name": "tickets", "permission_ids": ["datastore.table.read", "datastore.record.read", "datastore.record.write"] },
      { "resource_type": "datastore_table", "resource_name": "csat", "permission_ids": ["datastore.table.read", "datastore.record.read"] },
      { "resource_type": "datastore_table", "resource_name": "drafts", "permission_ids": ["datastore.table.read", "datastore.record.read", "datastore.record.write"] },
      { "resource_type": "datastore_table", "resource_name": "ticket_events", "permission_ids": ["datastore.table.read", "datastore.record.read", "datastore.record.write"] }
    ]
  }
}
